{
  "buildCommand": "cd FinSpark-Integration-Orchestrator && npm install && npm run build",
  "outputDirectory": "FinSpark-Integration-Orchestrator/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "@vite_api_base_url"
  }
}
